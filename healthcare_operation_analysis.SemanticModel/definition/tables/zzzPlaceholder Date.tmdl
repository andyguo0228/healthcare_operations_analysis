table 'zzzPlaceholder Date'
	lineageTag: 57460713-ba0f-4b94-8197-706c3ab3f99a

	column Date
		dataType: dateTime
		formatString: Long Date
		lineageTag: 2311cc38-cbd5-432a-8204-ef9fa43f70e3
		summarizeBy: none
		sourceColumn: Date

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	partition 'zzzPlaceholder Date' = m
		mode: import
		source =
				let
				    Source = List.Dates(
				        Date.From(DateTime.LocalNow()),
				        5,
				        #duration(1, 0, 0, 0)
				    ),
				
				    DateTable = Table.FromList(
				        Source,
				        Splitter.SplitByNothing(),
				        {"Date"},
				        null,
				        ExtraValues.Error
				    ),
				    #"Changed Type" = Table.TransformColumnTypes(DateTable, {{"Date", type date}})
				in
				    #"Changed Type"

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

