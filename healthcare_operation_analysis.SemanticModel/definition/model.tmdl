model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_ProTooling = ["DevMode","TMDLView_Desktop"]

annotation PBI_QueryOrder = ["helper_arrivaltimes","raw_Appointments","_Measures","Appointments","Rooms","Patients","Providers","Treatments","Date"]

ref table _Measures
ref table Date
ref table Patients
ref table Treatments
ref table Providers
ref table Rooms
ref table Appointments

ref cultureInfo en-US

